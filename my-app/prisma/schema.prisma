generator client {
  provider = "prisma-client-js"
}

// Configured for Production Deployment
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  location  String
  // We'll store interests as a serialized JSON string or a comma-separated string
  interests String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
